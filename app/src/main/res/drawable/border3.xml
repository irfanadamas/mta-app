<?xml version="1.0" encoding="utf-8"?>

<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <stroke
        android:width="2dp"
        android:color="#002060" />
    <solid
        android:color="#FFFFFF"
        android:paddingLeft="10dp"
        android:paddingTop="5dp"/>
    <padding
        android:left="5dp"
        android:top="5dp"
        android:right="5dp"
        android:bottom="5dp" />
    <corners
        android:radius="2dp" />

    <gradient
        android:angle="90"
        android:startColor="#F1F9FF"
        android:centerColor="#F1F9FF"
        android:endColor="#F1F9FF"
        android:type="linear"
        />
</shape>
