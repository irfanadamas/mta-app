<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:background="@color/shidt_detail_color"
    android:gravity="left"
    android:layout_gravity="right"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    >



    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/blue_206"
        android:orientation="vertical"
        android:paddingStart="15dp">

        <ImageView
            android:id="@+id/ImageExit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="right"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            app:srcCompat="@drawable/close" />

        <TextView
            android:id="@+id/txtRecipient_menu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:fontFamily="@font/roboto"
            android:gravity="left"
            android:text="Booking Menu"
            android:textColor="#fff" />

        <TextView
            android:id="@+id/txtRecipient_address_menu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/roboto"
            android:gravity="left"
            android:textColor="#fff"
            android:textSize="10sp" />


    </androidx.appcompat.widget.LinearLayoutCompat>

            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/rl_menu_main"
                android:layout_width="250dp"
                android:layout_height="wrap_content"
                android:background="#fff"
                android:layout_gravity="right"
                android:orientation="vertical"
                android:paddingStart="15dp"
              >


                <TextView
                    android:id="@+id/txtStartJob"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="@font/roboto_medium"
                    android:gravity="start"
                    android:text="Start Job"
                    android:textColor="#171313"
                    android:textSize="14sp"
                  />

                <TextView
                    android:id="@+id/txtEndJob"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="@font/roboto_medium"
                    android:gravity="start"
                    android:text="End Job"
                    android:textColor="#171313"
                    android:textSize="14sp"
                    />

                <TextView
                    android:id="@+id/txtSetTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="16dp"
                    android:fontFamily="@font/roboto_medium"
                    android:gravity="start"
                    android:text="Set Time"

                    android:textColor="#171313"
                    android:textSize="14sp"
                 />
            </androidx.appcompat.widget.LinearLayoutCompat>

   <ScrollView
        android:id="@+id/scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/rl_menu_detail"
                android:layout_width="250dp"
                android:layout_height="match_parent"
                android:layout_marginBottom="16dp"
                android:background="@color/shidt_detail_color"
                android:paddingStart="15dp"
                android:layout_gravity="right"
                android:gravity="left"
               android:orientation="vertical">

                <TextView
                    android:id="@+id/txtUploadPhoto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="@font/roboto_medium"
                    android:gravity="left"

                    android:text="Upload Photo"
                    android:textColor="#171313"
                    android:textSize="14sp"
                    />

                <TextView
                    android:id="@+id/txtTravelClaim"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="@font/roboto_medium"
                    android:gravity="start"
                    android:text="Travel Claim"

                    android:textColor="#171313"
                    android:textSize="14sp"
                    />



                <TextView
                    android:id="@+id/txtClientNote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="@font/roboto_medium"
                    android:gravity="left"
                    android:text="Client Notes"
                    android:textColor="#171313"
                    android:textSize="14sp"
                 />

                <TextView
                    android:id="@+id/txtServiceNote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="@font/roboto_medium"
                    android:gravity="start"
                    android:text="Shift Report"

                    android:textColor="#171313"
                    android:textSize="14sp"
                    />

                <TextView
                    android:id="@+id/txtRecordIncident"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="@font/roboto_medium"
                    android:gravity="start"
                    android:text="Record Incident"
                    android:textColor="#171313"
                    android:textSize="14sp"
                 />

                <TextView
                    android:id="@+id/txtSignature"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="@font/roboto_medium"
                    android:gravity="start"

                    android:text="Signature"
                    android:textColor="#171313"
                    android:textSize="14sp"
                    />
                <TextView
                    android:id="@+id/txtViewPlanGoals"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginEnd="8dp"

                    android:fontFamily="@font/roboto_medium"
                    android:gravity="left"
                    android:text="View Plan Goals"
                    android:textColor="#171313"
                    android:textSize="14sp"
                    />

                <TextView
                    android:id="@+id/txtViewClientDocuments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="16dp"
                    android:fontFamily="@font/roboto_medium"
                    android:gravity="left"
                    android:text="View Client Documents"

                    android:textColor="#171313"
                    android:textSize="14sp"
                    />


            </androidx.appcompat.widget.LinearLayoutCompat>

    </ScrollView>
</androidx.appcompat.widget.LinearLayoutCompat>