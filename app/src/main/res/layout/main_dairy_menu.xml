<?xml version="1.0" encoding="utf-8"?>
    <androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:background="@color/shidt_detail_color"
        android:gravity="left"
        android:layout_gravity="end"
        android:fitsSystemWindows="true"
        android:orientation="vertical"
        >


        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/blue_206"
            android:orientation="horizontal"
            android:paddingStart="15dp">

            <!-- Left Avatar -->
            <ImageView
                android:id="@+id/imageView5"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"
                android:src="@drawable/avatar" />

            <!-- Middle Text -->
            <TextView
                android:id="@+id/txtStaff_menu"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="8dp"
                android:text="Staff Menu"
                android:textColor="#fff"
                android:fontFamily="@font/roboto"
                android:textSize="16sp" />

            <!-- Right Exit Icon -->
            <ImageView
                android:id="@+id/ImageExit"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginTop="18dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="8dp"

                android:src="@drawable/close" />
        </androidx.appcompat.widget.LinearLayoutCompat>




    <ScrollView
        android:id="@+id/scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.LinearLayoutCompat
            android:id="@+id/rl_menu_detail"
            android:layout_width="250dp"
            android:layout_height="match_parent"
            android:layout_marginBottom="16dp"
            android:background="@color/shidt_detail_color"
            android:paddingStart="15dp"
            android:layout_gravity="right"
            android:gravity="left"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtRefresh"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="32dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/roboto"
                android:gravity="left"

                android:text="Refresh"
                android:textColor="#171313"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/txtShowAll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="32dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/roboto"
                android:gravity="start"
                android:text="Show All"

                android:textColor="#171313"
                android:textSize="16sp" />


            <TextView
                android:id="@+id/txtAddLeave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="32dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/roboto"
                android:gravity="left"
                android:text="Add Leave"
                android:textColor="#171313"
                android:textSize="16sp" />


            <TextView
                android:id="@+id/txtAddAvailability"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="32dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/roboto"
                android:gravity="start"
                android:text="Add Availability"
                android:textColor="#171313"
                android:textSize="16sp" />


            <TextView
                android:id="@+id/txtAcceptRosters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="32dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/roboto"
                android:gravity="start"
                android:text="Accept Rosters"
                android:textColor="#171313"
                android:textSize="16sp" />


            <TextView
                android:id="@+id/txtExit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="32dp"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="32dp"
                android:fontFamily="@font/roboto"
                android:gravity="left"
                android:text="Logout"
                android:textColor="#171313"
                android:textSize="16sp" />


        </androidx.appcompat.widget.LinearLayoutCompat>

    </ScrollView>
</androidx.appcompat.widget.LinearLayoutCompat>