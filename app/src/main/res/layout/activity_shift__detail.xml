                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="2dp"
                    app:cardElevation="0dp"
                    app:layout_constraintTop_toBottomOf="@id/cardView41">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingBottom="10dp">

                        <TextView
                            android:id="@+id/txtExtraInfo"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="28dp"
                            android:layout_marginTop="4dp"

                            android:layout_marginEnd="8dp"
                            android:layout_marginBottom="10dp"
                            android:fontFamily="@font/roboto"
                            android:lineSpacingExtra="5dp"
                            android:textColor="#000"
                            android:textSize="14sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintHorizontal_bias="0.0"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/txtExtraInfo_Label" />

                        <TextView
                            android:id="@+id/txtRunsheetAlert_Label"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="28dp"
                            android:layout_marginTop="10dp"
                            android:layout_marginEnd="8dp"
                            android:fontFamily="@font/roboto_medium"
                            android:text="Runsheet Alerts"
                            android:textColor="#000"

                            android:textSize="14sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintHorizontal_bias="0.0"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/txtRunsheetAlert"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="28dp"
                            android:layout_marginTop="10dp"
                            android:layout_marginEnd="8dp"

                            android:fontFamily="@font/roboto"
                            android:lineSpacingExtra="3dp"
                            android:textColor="#000"
                            android:textSize="14sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintHorizontal_bias="0.0"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/txtCarePlanAlert" />

                        <TextView
                            android:id="@+id/txtCarePlanAlert"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"

                            android:layout_marginStart="28dp"
                            android:layout_marginTop="8dp"
                            android:layout_marginEnd="8dp"
                            android:background="#fff"
                            android:fontFamily="@font/roboto"
                            android:lineSpacingExtra="3dp"
                            android:textColor="#000"
                            android:textSize="14sp"
                            android:visibility="visible"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/txtRunsheetAlert_Label" />

                        <TextView
                            android:id="@+id/txtExtraInfo_Label"
