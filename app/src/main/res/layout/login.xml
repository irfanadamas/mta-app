<?xml version="1.0" encoding="utf-8"?>
    <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        tools:context=".Login">
    <ScrollView
        android:id="@+id/scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="#fff">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">


            <Button
                android:id="@+id/btnOk"
                android:layout_width="256sp"
                android:layout_height="48dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/btn_ok_login"
                android:focusable="true"
                android:text="LOGIN"
                android:textColor="#ffffff"
               
                android:textSize="18sp"

                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/txtPassword" />

            <Button
                android:id="@+id/btnSettings"
                android:layout_width="256sp"
                android:layout_height="48dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/btn_dark_blue"
                android:text="SETTINGS"
                android:textColor="#ffffff"
               
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/btnOk" />


            <EditText
                android:id="@+id/txtUser"
                android:layout_width="257dp"
                android:layout_height="48dp"
                android:layout_marginStart="8sp"
                android:layout_marginEnd="8sp"
                android:background="@drawable/rounded_border_edittext2"
                android:hint="txtUsername"
                android:inputType="textWebEditText"
                android:lines="1"
                android:paddingStart="15sp"
                android:text=""
                android:textColor="@color/login_text_color"
                android:textCursorDrawable="@color/color_cursor"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/imageView">


            </EditText>

            <EditText
                android:id="@+id/txtPassword"

                android:layout_width="257sp"
                android:layout_height="48dp"
                android:layout_marginStart="8sp"
                android:layout_marginTop="32dp"
                android:layout_marginEnd="8sp"
                android:background="@drawable/rounded_border_edittext2"
                android:hint="Password"
                android:inputType="textPassword"
                android:lines="1"
                android:paddingStart="15sp"

                android:text=""
                android:textColor="@color/login_text_color"
                android:textCursorDrawable="@color/color_cursor"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/txtUser">


            </EditText>


            <ImageView
                android:id="@+id/imageView"
                android:layout_width="0sp"
                android:layout_height="wrap_content"


                android:background="@drawable/loginscreen2"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="1.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/txtCompanyLink"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8sp"

                android:layout_marginTop="8dp"
                android:layout_marginEnd="8sp"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/roboto_medium"
                android:gravity="center_horizontal"
                android:text="Adamas Corporate Solutions"
                android:textColor="#ffffff"
                android:textSize="18sp"
                app:layout_constraintBottom_toBottomOf="@+id/imageView"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/imageView"
                app:layout_constraintVertical_bias="0.07999998" />

            <TextView
                android:id="@+id/textMsg"
                android:layout_width="250dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16sp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="8sp"
                android:layout_marginBottom="8sp"
                android:gravity="center_horizontal"
                android:textColor="#FF0000"
                android:textSize="12sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/btnSettings"
                app:layout_constraintVertical_bias="0.100000024" />


    <TextView
        android:id="@+id/txtPinLabel"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_marginStart="32dp"

        android:layout_marginEnd="32dp"
        android:layout_marginBottom="16dp"
        android:gravity="center"
        android:text="ENTER 4-7 DIGIT PIN CODE"
        android:textColor="#000"
        app:layout_constraintBottom_toTopOf="@+id/txtPassword"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.333"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageView" />

            <ImageView
                android:id="@+id/imageView4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="32dp"
                app:layout_constraintBottom_toTopOf="@+id/txtUser"
                app:layout_constraintEnd_toEndOf="@+id/imageView"
                app:layout_constraintHorizontal_bias="0.76"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/txtCompanyLink"
                app:layout_constraintVertical_bias="0.352"
                app:srcCompat="@drawable/mobile" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>


