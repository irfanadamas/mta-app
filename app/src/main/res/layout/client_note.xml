<?xml version="1.0" encoding="utf-8"?>

    <RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:keepScreenOn="true"
        android:fillViewport="true"
        android:fitsSystemWindows="true"
        android:background="@color/bg_default">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:scrollbarStyle="insideOverlay"
        android:scrollbars="vertical"
        android:background="#fff"
        >

        <RelativeLayout
            android:id="@+id/rl_main"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_alignParentTop="true"
            android:gravity="center"

            android:padding="1dp">

    <RelativeLayout
        android:id="@+id/guideline1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/background3"
         >


        <TextView
            android:id="@+id/txt1"
            android:layout_width="match_parent"
            android:layout_height="50dp"

            android:background="#3355ff"
            android:gravity="center"
            android:text="@string/Client_Note_Title"


            android:textColor="#fff"
            android:textStyle="bold" />
    </RelativeLayout>


    <RelativeLayout
        android:id="@+id/guideline2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
     
        android:layout_below="@+id/guideline1"
         >


        <CheckBox
            android:id="@+id/chkOPNote"
            android:layout_width="135dp"
            android:layout_height="23dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            android:checked="true"
            android:visibility="gone"
            android:text=" OP Note "
            android:textColor="#000000"
            android:textSize="14dp"
            />


    <CheckBox
        android:id="@+id/chkCaseNote"
        android:layout_width="135dp"
        android:layout_height="27dp"
        android:layout_alignTop="@+id/chkOPNote"
        android:layout_toRightOf="@+id/chkOPNote"
        android:text=" Case Note "
        android:textColor="#000000"
        android:visibility="gone"
        android:textSize="14dp"
         />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
         
            android:layout_below="@+id/chkOPNote"
            >

        <CheckBox
            android:id="@+id/chkServiceNote"
            android:layout_width="135dp"
            android:layout_height="27dp"
            android:visibility="gone"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:text=" Service Note "
            android:textColor="#000000"
            android:textSize="14dp"

             />


    <CheckBox
        android:id="@+id/chkClinicalNotes"
        android:layout_width="144dp"
        android:layout_height="23dp"
        android:layout_marginStart="16dp"
        android:layout_alignTop="@+id/chkServiceNote"
        android:layout_toRightOf="@+id/chkServiceNote"
        android:visibility="gone"
        android:text=" Clinical Note "
        android:textColor="#000000"
        android:textSize="14dp"

         />


        <CheckBox
            android:id="@+id/chkIncidentNote"
            android:layout_width="129dp"
            android:layout_height="25dp"
            android:layout_below="@+id/chkServiceNote"
            android:layout_marginLeft="17dp"
            android:text=" Incident Note "
            android:textColor="#000000"
            android:textSize="14dp"
            android:visibility="gone"
            />
    </RelativeLayout>
    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/rl_Shift_Note"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
     
        android:layout_below="@+id/guideline2"

        >

    <RelativeLayout
        android:id="@+id/guideline3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
     
        android:background="@drawable/border"
        >

        <TextView
            android:id="@+id/textView7"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"

            android:paddingStart="4dp"
            android:text="SHIFT REPORT FOR: "
            android:textColor="@color/common_google_signin_btn_text_dark_focused"
            android:textStyle="bold"

            />

        <TextView
        android:id="@+id/txtShiftDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginEnd="2dp"
        android:layout_marginBottom="2dp"

        android:paddingStart="5dp"
        android:text="Date"
        android:textColor="@color/common_google_signin_btn_text_dark_focused"
            android:layout_toRightOf="@+id/textView7"
         />


    </RelativeLayout>
    <RelativeLayout
        android:id="@+id/guideline4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
     
        android:layout_below="@+id/guideline3" >


    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="2dp"

        android:background="@drawable/background2"
        android:paddingLeft="5dp"
        android:text="SHIFT GOAL/S:"
        android:textColor="@color/common_google_signin_btn_text_dark_focused"
        android:textStyle="bold"
         />

</RelativeLayout>
    <RelativeLayout
        android:id="@+id/guideline5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
     
        android:layout_below="@+id/guideline4"
         >

    <Spinner
        android:id="@+id/txtShiftgoals"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginStart="2dp"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="2dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/background3"
        android:paddingStart="3dp"

        android:spinnerMode="dropdown"
        android:text="Shift Goal: "
         />
    </RelativeLayout>
    <RelativeLayout
        android:id="@+id/guideline6"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        android:layout_below="@+id/guideline5"
         >

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="2dp"
        android:background="@drawable/background2"
        android:paddingStart="5dp"
        android:text="SHIFT PURPOSE"
        android:textColor="@color/common_google_signin_btn_text_dark_focused"
        android:textStyle="bold"
         />
    </RelativeLayout>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/guideline6"
         >

    <EditText
        android:id="@+id/txtShiftPurpose"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:imeOptions="actionDone"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="2dp"
        android:padding="5dp"
        android:background="@drawable/border"
        android:gravity="left"
        android:textSize="12dp"
        android:inputType="textMultiLine"
        />


    </RelativeLayout>

    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/guideline8"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
     
        android:layout_below="@+id/rl_Shift_Note"
    >

    <TextView
        android:id="@+id/lbl1RosterNote"
        android:layout_width="match_parent"
        android:layout_height="25dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="2dp"
        android:textStyle="bold"
        android:background="@drawable/background2"
        android:gravity="center_vertical"
        android:paddingStart="5dp"
        android:text=" CLIENT NOTE "
        android:textColor="#000000"
        android:textSize="14dp"
        />


    <EditText
        android:id="@+id/txtRosterNote"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="2dp"
        android:layout_below="@+id/lbl1RosterNote"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="4dp"
        android:imeOptions="actionDone"
        android:background="@drawable/border"
        android:padding="5dp"
        android:textSize="14dp"
        android:gravity="left"
        android:inputType="textMultiLine"

   />
    </RelativeLayout>
        <RelativeLayout
            android:id="@+id/rl_Shift_Note2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:layout_below="@+id/guideline8"
            >
            <RelativeLayout
                android:id="@+id/rl_Shift_Note21"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"


                >
            <TextView
                android:id="@+id/lblAction"
                android:layout_width="match_parent"
                android:layout_height="25dp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="4dp"
                android:layout_marginBottom="2dp"
                android:textStyle="bold"
                android:background="@drawable/background2"
                android:gravity="center_vertical"
                android:paddingStart="5dp"
                android:text=" ACTIONS "
                android:textColor="#000000"
                android:textSize="14dp"
                />


            <EditText
                android:id="@+id/txtAction"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="2dp"
                android:layout_below="@+id/lblAction"
                android:layout_marginEnd="4dp"
                android:layout_marginBottom="4dp"
                android:imeOptions="actionDone"
                android:background="@drawable/border"
                android:padding="5dp"
                android:textSize="14dp"
                android:gravity="left"
                android:inputType="textMultiLine"

                />
            </RelativeLayout>
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/rl_Shift_Note21"
                    >
                    <TextView
                        android:id="@+id/lbloutCome"
                        android:layout_width="match_parent"
                        android:layout_height="25dp"
                        android:layout_marginStart="8dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginEnd="4dp"
                        android:layout_marginBottom="2dp"
                        android:textStyle="bold"
                        android:background="@drawable/background2"
                        android:gravity="center_vertical"
                        android:paddingStart="5dp"
                        android:text=" OUTCOME "
                        android:textColor="#000000"
                        android:textSize="14dp"
                        />


                    <EditText
                        android:id="@+id/txtOutCome"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginStart="8dp"
                        android:layout_marginTop="2dp"
                        android:layout_below="@+id/lbloutCome"
                        android:layout_marginEnd="4dp"
                        android:layout_marginBottom="4dp"
                        android:imeOptions="actionDone"
                        android:background="@drawable/border"
                        android:padding="5dp"
                        android:textSize="14dp"
                        android:gravity="left"
                        android:inputType="textMultiLine"

                        />
                </RelativeLayout>
        </RelativeLayout>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginBottom="10dp"
        android:padding="10dp"
        android:layout_below="@+id/rl_Shift_Note2" >

    <Button
        android:id="@+id/btnExit"
        android:layout_width="77dp"
        android:layout_height="48dp"

        android:height="60dp"
        android:background="@drawable/button_new"
        android:drawableLeft="@drawable/ic_exit"
        android:text=" Exit"
        android:textColor="#000"
    />

    <Button
        android:id="@+id/btnOK"
        android:layout_width="86dp"
        android:layout_height="47dp"


        android:layout_toRightOf="@+id/btnExit"
        android:height="60dp"
        android:background="@drawable/button_new"
        android:drawableLeft="@drawable/ic_save"
        android:text=" Save"
        android:textColor="#000"
    />
    </RelativeLayout>
        </RelativeLayout>
    </ScrollView>


</RelativeLayout>