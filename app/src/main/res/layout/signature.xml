<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/power_blue"
    android:gravity="center"
     >



    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:padding="10dp" >


        <RelativeLayout
            android:id="@+id/rl_main"
            android:layout_width="500dp"
            android:layout_height="500dp"
            android:gravity="center"
            android:background="@drawable/border2"
            android:padding="10dp" >


            <LinearLayout android:layout_height="wrap_content"
                android:id="@+id/linearLayout2" android:layout_width="match_parent">
                <Button android:layout_height="50dp" android:layout_weight=".30"
                    android:text="Exit" android:layout_width="0dp" android:id="@+id/cancel" />
                <Button android:layout_height="50dp" android:layout_weight=".35"
                    android:text="Clear" android:layout_width="0dp" android:id="@+id/clear" />
                <Button android:layout_height="50dp" android:layout_weight=".35"
                    android:text="Register" android:layout_width="0dp" android:id="@+id/getsign" />
            </LinearLayout>
            <TableLayout android:layout_height="wrap_content"
                android:id="@+id/tableLayout1"
                android:layout_width="match_parent"
                android:layout_below="@+id/linearLayout2"
                >
                <TableRow
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <TextView android:layout_height="wrap_content"
                        android:text="User : " android:textAppearance="?android:attr/textAppearanceMedium"
                        android:layout_width="wrap_content" android:paddingLeft="10sp"
                        android:textColor="#000"
                        android:layout_gravity="right" />
                    <EditText android:layout_height="wrap_content"
                        android:id="@+id/txtUser"
                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:inputType="textWebEditText"
                        android:lines="1"
                        android:maxLength="30">
                        <requestFocus/>
                    </EditText>
                </TableRow>
                <TableRow android:id="@+id/tableRow1" android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <TextView android:layout_height="wrap_content"
                        android:text="Password"
                        android:textAppearance="?android:attr/textAppearanceMedium"
                        android:layout_width="wrap_content"
                        android:paddingLeft="10sp"
                        android:textColor="#000"
                        android:layout_gravity="right" />
                    <EditText android:layout_height="wrap_content"
                        android:id="@+id/txtPassword"
                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:inputType="textPassword"
                        android:lines="1"
                        android:maxLength="30">

                    </EditText>
                </TableRow>
                <TableRow
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <TextView android:layout_height="wrap_content"
                        android:text="" android:maxLength="30"
                        android:textAppearance="?android:attr/textAppearanceMedium"
                        android:layout_width="wrap_content" />
                    <TextView android:layout_height="wrap_content" android:id="@+id/lblMsg"
                        android:text="Please Sign below ..." android:maxLength="30"
                        android:textAppearance="?android:attr/textAppearanceMedium"
                        android:textColor="#000"
                        android:layout_width="wrap_content" />
                </TableRow>
            </TableLayout>
            <LinearLayout android:layout_height="350dp"
                android:layout_below="@+id/tableLayout1"
                android:id="@+id/linearLayout"
                android:layout_width="match_parent"
                android:orientation="horizontal" />

        </RelativeLayout>


    </RelativeLayout>



</RelativeLayout>