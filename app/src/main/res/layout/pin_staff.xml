<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:id="@+id/linearLayout1"
    android:layout_width="300dp"
     android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:orientation="vertical"
    android:fillViewport="true"
    android:fitsSystemWindows="true"
    android:background="@color/bg_default"
    xmlns:android="http://schemas.android.com/apk/res/android"
     >
    
    <LinearLayout android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:layout_marginLeft="10dp"     
        android:layout_gravity="center"
        android:gravity="center"
        android:id="@+id/linearLayout2" android:layout_width="match_parent">
        
        <Button android:layout_height="50dp" 
            android:text="Exit" android:layout_width="90dp" android:id="@+id/cancel" />
        <Button android:layout_height="50dp" 
            android:text="Clear" android:layout_width="90dp" android:id="@+id/clear" />
       
    </LinearLayout>
    <TableLayout android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:id="@+id/tableLayout1" android:layout_width="wrap_content">
        <TableRow android:id="@+id/tableRow1" android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView android:layout_height="50dp"
                android:text="Enter Staff Pin code: " 
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:layout_width="wrap_content" 
                android:paddingLeft="10dp"
                android:paddingTop="10dp"
                android:textColor="#000"
                android:layout_gravity="right" />
         </TableRow>
         <TableRow
             android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            
            <EditText android:layout_height="wrap_content" 
                android:id="@+id/txtStaff_pin"
                android:layout_marginLeft="1dp"
                android:layout_weight="1" 
                android:layout_width="100dp"
                android:inputType="textPassword"
                android:lines="1"
                     
                android:maxLength="30">
                <requestFocus/>
            </EditText>
        </TableRow>
       <TableRow
           android:layout_width="fill_parent"
            android:layout_height="fill_parent">
            
           <Button
                        android:id="@+id/getsign"
                        style="@style/btn_form"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/btn_blue"
                        android:drawableLeft="@drawable/login"
                        android:text="Login"
                        android:height="55dp" />
           </TableRow>
           
        
       <TableRow
           android:layout_width="fill_parent"
            android:layout_height="fill_parent">
            
           <Button
                        android:id="@+id/btnLogoutPin"
                        style="@style/btn_form"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/btn_orange"
                        android:drawableLeft="@drawable/cancel"
                        android:text="Logout"
                        android:height="55dp" />
           </TableRow>
           
            <TableRow
                android:layout_width="fill_parent"
            android:layout_height="fill_parent">
            <TextView android:layout_height="wrap_content" 
                android:id="@+id/txtPinMsg"
                android:layout_marginLeft="1dp"
                android:layout_weight="1" 
                android:layout_width="fill_parent"             
               >
              
            </TextView>


        </TableRow>
        <TableRow
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:layout_marginBottom="20dp">

        </TableRow>
        <TableRow
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
             android:layout_marginBottom="20dp">
            <ImageView android:layout_height="wrap_content"
                android:layout_marginLeft="1dp"
                android:layout_weight="1" 
                android:layout_width="fill_parent"  
                android:background="@drawable/login4"           
               >
              
            </ImageView>
        </TableRow>
    </TableLayout>
  
</LinearLayout>